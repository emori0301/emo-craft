# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/slack_emoji_generator?schema=public"

# Better Auth (BETTER_AUTH_URL は dev サーバーの表示 URL と一致させること。127.0.0.1 で起動する場合は 127.0.0.1 を使用)
BETTER_AUTH_SECRET="change-this-secret-key-in-production"
BETTER_AUTH_URL="http://127.0.0.1:3000"

# OAuth (optional - add your credentials)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

